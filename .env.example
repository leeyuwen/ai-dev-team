# AI Provider 选择 (openai / minimax / anthropic / zhipuai / ollama)
AI_PROVIDER=minimax

# OpenAI 配置 (如果 AI_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4

# MiniMax 配置 (如果 AI_PROVIDER=minimax)
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_MODEL=abab6.5s
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# Anthropic 配置 (如果 AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# 智谱AI 配置 (如果 AI_PROVIDER=zhipuai)
ZHIPUAI_API_KEY=your_zhipuai_api_key
ZHIPUAI_MODEL=glm-4

# Ollama 本地配置 (如果 AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# 全局配置
TEMPERATURE=0.7